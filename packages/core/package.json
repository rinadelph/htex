{
  "name": "@htex/core",
  "version": "0.0.1",
  "description": "Framework-agnostic LaTeX to HTML/SVG rendering engine",
  "keywords": ["latex", "html", "svg", "typescript", "rendering", "pretext"],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "htex": "./src/cli.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "!src/**/*.test.ts"],
  "scripts": {
    "build": "bun run build:package",
    "build:package": "rm -rf dist && tsc -p tsconfig.build.json",
    "check": "tsc --noEmit",
    "test": "bun test src"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.4",
    "katex": "^0.16.45"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/bun": "latest",
    "svelte": "^5.55.1",
    "typescript": "~5.4.0",
    "vite": "^8.0.3"
  }
}
